#!/bin/bash
# claude-code-kit pre-commit hook
# Auto-installed by session-check.py

set -e

# Python 파일 ruff check
if command -v ruff &>/dev/null; then
    # NUL 구분자로 공백 포함 파일명 안전 처리
    STAGED_PY=$(git diff --cached --name-only -z --diff-filter=ACM | tr '\0' '\n' | grep '\.py$' || true)
    if [ -n "$STAGED_PY" ]; then
        git diff --cached --name-only -z --diff-filter=ACM | grep -z '\.py$' | xargs -0 ruff check --fix
        git diff --cached --name-only -z --diff-filter=ACM | grep -z '\.py$' | xargs -0 git add
    fi
fi
