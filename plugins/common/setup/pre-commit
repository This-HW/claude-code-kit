#!/bin/bash
# claude-code-kit pre-commit hook
# Auto-installed by session-check.py

set -e

# Python 파일 ruff check
if command -v ruff &>/dev/null; then
    # macOS/Linux 호환: tr로 NUL→줄바꿈 변환 후 grep, 재NUL화
    STAGED_PY=$(git diff --cached --name-only --diff-filter=ACM | grep '\.py$' || true)
    if [ -n "$STAGED_PY" ]; then
        while IFS= read -r f; do
            ruff check --fix "$f"
            git add "$f"
        done <<< "$STAGED_PY"
    fi
fi

# JSON 파일 유효성 검증
STAGED_JSON=$(git diff --cached --name-only --diff-filter=ACM | grep '\.json$' || true)
if [ -n "$STAGED_JSON" ]; then
    while IFS= read -r f; do
        if ! python3 -m json.tool "$f" > /dev/null 2>&1; then
            echo "❌ Invalid JSON: $f"
            exit 1
        fi
    done <<< "$STAGED_JSON"
fi

# plugins/ 하위 .md 파일 frontmatter 필수값 검증
STAGED_MD=$(git diff --cached --name-only --diff-filter=ACM | grep '^plugins/.*\.md$' || true)
if [ -n "$STAGED_MD" ]; then
    python3 - <<'PYEOF'
import sys, re, pathlib, subprocess

result = subprocess.run(
    ["git", "diff", "--cached", "--name-only", "--diff-filter=ACM"],
    capture_output=True, text=True
)
files = [f for f in result.stdout.splitlines() if f.startswith("plugins/") and f.endswith(".md")]

errors = []
for fpath in files:
    p = pathlib.Path(fpath)
    if not p.exists():
        continue
    content = p.read_text(encoding="utf-8")
    if not content.startswith("---"):
        continue  # frontmatter 없는 파일은 스킵 (README 등)
    m = re.match(r"^---\n(.*?)\n---", content, re.DOTALL)
    if not m:
        continue
    fm = m.group(1)
    if "name:" not in fm:
        errors.append(f"{fpath}: frontmatter에 'name:' 필드 없음")
    if "description:" not in fm:
        errors.append(f"{fpath}: frontmatter에 'description:' 필드 없음")

if errors:
    for e in errors:
        print(f"❌ {e}")
    sys.exit(1)
PYEOF
fi
