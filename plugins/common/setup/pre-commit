#!/bin/bash
# claude-code-kit pre-commit hook
# Auto-installed by session-check.py

set -e

# Python 파일 ruff check
if command -v ruff &>/dev/null; then
    # macOS/Linux 호환: tr로 NUL→줄바꿈 변환 후 grep, 재NUL화
    STAGED_PY=$(git diff --cached --name-only --diff-filter=ACM | grep '\.py$' || true)
    if [ -n "$STAGED_PY" ]; then
        echo "$STAGED_PY" | xargs ruff check --fix
        echo "$STAGED_PY" | xargs git add
    fi
fi
